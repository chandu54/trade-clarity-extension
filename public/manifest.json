{
  "name": "TradeClarity.market",
  "description": "Elevate your trading discipline with TradeClarity.market. A professional-grade research terminal featuring institutional AI insights.",
  "author": "TradeClarity Team",
  "version": "1.0.0",
  "manifest_version": 3,
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://query1.finance.yahoo.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_title": "Open TradeClarity.market",
    "default_icon": {
      "16": "app_logo.png",
      "32": "app_logo.png",
      "48": "app_logo.png",
      "128": "app_logo.png"
    }
  },
  "icons": {
    "16": "app_logo.png",
    "32": "app_logo.png",
    "48": "app_logo.png",
    "128": "app_logo.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.tradingview.com/chart/*",
        "*://*.screener.in/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.css", "dashboard.html"],
      "matches": [
        "*://*.tradingview.com/*",
        "*://*.screener.in/*"
      ]
    }
  ]
}