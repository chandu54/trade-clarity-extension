{
  "name": "TradeClarity",
  "description": "Your disciplined path to smarter trades. Manage weekly watchlists, analyze setups, and maintain trading discipline with AI insights.",
  "version": "1.0.0",
  "manifest_version": 3,
  "permissions": ["storage", "unlimitedStorage", "activeTab"],
  "host_permissions": [
    "https://query1.finance.yahoo.com/*"
  ],
  "action": {
    "default_title": "Open TradeClarity"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.tradingview.com/chart/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.css", "dashboard.html"],
      "matches": ["*://*.tradingview.com/*"]
    }
  ]
}