{
  "name": "TradeClarity",
  "description": "Professional swing trading companion for managing disciplined watchlists. Features weekly routines, automated metrics (ADR/Liquidity), and deep-view AI analysis integrated with TradingView.",
  "author": "TradeClarity Team",
  "version": "1.0.0",
  "manifest_version": 3,
  "permissions": ["storage", "unlimitedStorage", "activeTab"],
  "host_permissions": [
    "https://query1.finance.yahoo.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_title": "Open TradeClarity"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.tradingview.com/chart/*",
        "*://*.screener.in/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.css", "dashboard.html"],
      "matches": [
        "*://*.tradingview.com/*",
        "*://*.screener.in/*"
      ]
    }
  ]
}